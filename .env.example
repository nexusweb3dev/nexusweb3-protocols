# === AgentVault Deployment Config ===

# Your deployer wallet private key (with 0x prefix)
PRIVATE_KEY=0x...

# Deployer wallet address (derived from PRIVATE_KEY)
DEPLOYER_ADDRESS=0x...

# Fee recipient address (where 0.1% protocol fee goes)
# Can be same as DEPLOYER_ADDRESS for now
FEE_RECIPIENT=0x...

# Fee in basis points (10 = 0.1%, 25 = 0.25%, 50 = 0.5%)
FEE_BPS=10

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Block explorer API key (free from basescan.org)
BASESCAN_API_KEY=...
