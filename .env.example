# === NexusWeb3 Deployment Config ===

# Deployer wallet private key (with 0x prefix)
# Used for deployment scripts only
PRIVATE_KEY=0x...

# Deployer wallet address (derived from PRIVATE_KEY)
DEPLOYER_ADDRESS=0x...

# Agent operator key (for day-to-day agent operations)
# Recommended: use AgentVault operator with spending limit
ETH_OPERATOR_KEY=0x...

# Fee recipient address (where protocol fees go)
FEE_RECIPIENT=0x...

# Fee in basis points (10 = 0.1%, 25 = 0.25%, 50 = 0.5%)
FEE_BPS=10

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Block explorer API key (free from basescan.org)
BASESCAN_API_KEY=...
